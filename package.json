{
  "name": "gutu-plugin-treasury-core",
  "private": true,
  "type": "module",
  "workspaces": [
    "framework/builtin-plugins/*"
  ],
  "scripts": {
    "build": "cd framework/builtin-plugins/treasury-core && bun run build",
    "typecheck": "cd framework/builtin-plugins/treasury-core && bun run typecheck",
    "lint": "cd framework/builtin-plugins/treasury-core && bun run lint",
    "test": "cd framework/builtin-plugins/treasury-core && bun run test",
    "test:contracts": "cd framework/builtin-plugins/treasury-core && bun run test:contracts",
    "test:unit": "cd framework/builtin-plugins/treasury-core && bun run test:unit",
    "test:integration": "cd framework/builtin-plugins/treasury-core && bun test tests/integration",
    "test:migrations": "cd framework/builtin-plugins/treasury-core && bun test tests/migrations",
    "docs:summary": "node scripts/docs-summary.mjs",
    "docs:check": "node scripts/docs-check.mjs",
    "ci": "bun run build && bun run typecheck && bun run lint && bun run test && bun run docs:check"
  },
  "gutuEcosystem": {
    "defaultChannel": "next",
    "primaryPackage": "treasury-core"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "bun-types": "^1.3.13",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.39.4",
    "globals": "^16.5.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "5.8.3",
    "typescript-eslint": "^8.58.2",
    "zod": "^4.0.0"
  }
}
